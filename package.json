{
  "name": "runbook-lint",
  "version": "0.2.0",
  "description": "Audit incident runbooks for human and AI-agent executability.",
  "type": "module",
  "bin": {
    "runbook-lint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "CHANGELOG.zh-CN.md",
    "CONTRIBUTING.md",
    "CONTRIBUTING.zh-CN.md",
    "SECURITY.md",
    "SECURITY.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "check": "npm run build && npm run lint && npm run test",
    "smoke": "node dist/cli.js demo --out reports/demo",
    "package:check": "npm run check && npm run smoke && npm pack --dry-run --ignore-scripts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "runbook",
    "sre",
    "incident-response",
    "ai-agent",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.3"
  }
}
